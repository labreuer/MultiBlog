// Prisma schema for MultiBlog — see PLAN.md §4 for the data model rationale.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
  AUTHOR
  COMMENTER
}

enum ModerationPolicy {
  INHERIT
  ALWAYS
  AUTO
}

enum PublicationEventType {
  PUBLISHED
  UNPUBLISHED
  SCHEDULED
  SCHEDULE_CANCELED
}

enum ThreadStatus {
  ACTIVE
  DETACHED
  RESOLVED
}

enum CommentStatus {
  PENDING
  APPROVED
  SPAM
  DELETED
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  emailVerified    DateTime?
  name             String?
  image            String?
  passwordHash     String?
  role             Role              @default(COMMENTER)
  moderationPolicy ModerationPolicy  @default(INHERIT)
  color            String            @default("#5b8cff")
  adminInitials    String
  createdAt        DateTime          @default(now())

  accounts             Account[]
  sessions             Session[]
  postAuthors          PostAuthor[]
  revisions            Revision[]           @relation("RevisionEditor")
  commenter            Commenter?
  passwordResetTokens  PasswordResetToken[]
  commentStatusChanges Comment[]            @relation("CommentStatusChangedBy")
  commentDeletions     Comment[]            @relation("CommentDeletedBy")
  publicationEvents    PostPublicationEvent[] @relation("PublicationEventActor")
}

// Auth.js (NextAuth) Prisma adapter models — used for OAuth account linking.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id                String     @id @default(cuid())
  slug              String     @unique
  title             String
  publishRevisionId String?    @unique
  moderationPolicy  ModerationPolicy @default(INHERIT)
  createdAt         DateTime   @default(now())
  publishedAt       DateTime?  // may be in the future — see below

  // publishRevisionId is set immediately by both an immediate publish and a
  // *scheduled* one — visibility is gated by publishedAt vs now(), a pure
  // query-time condition (src/lib/post-status.ts's publishedPostWhere), not
  // a stored status or a background sweep that flips something at the
  // scheduled instant. See PLAN.md §4/§10.
  publishRevision Revision?          @relation("PublishRevision", fields: [publishRevisionId], references: [id])
  authors         PostAuthor[]
  revisions       Revision[]         @relation("PostRevisions")
  collab          PostCollab?
  collabUpdates   PostCollabUpdate[]
  threads         CommentThread[]
  publicationEvents PostPublicationEvent[]
}

model PostAuthor {
  postId      String
  userId      String
  bylineOrder Int

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
}

model Revision {
  id             String   @id @default(cuid())
  postId         String
  revisionNumber Int
  doc            Json
  title          String
  editorId       String?
  changelog      String?
  createdAt      DateTime @default(now())

  post              Post                   @relation("PostRevisions", fields: [postId], references: [id], onDelete: Cascade)
  editor            User?                  @relation("RevisionEditor", fields: [editorId], references: [id])
  publishedAsRevisionOf Post?               @relation("PublishRevision")
  threads           CommentThread[]
  publicationEvents PostPublicationEvent[]

  @@unique([postId, revisionNumber])
}

// Append-only audit log of publish/unpublish/schedule transitions. Needed
// because, once a no-op save/publish or an unpublish-republish cycle can
// happen without a new Revision row, Revision.createdAt alone can no longer
// answer "when did this go live/offline" — see PLAN.md §10.
model PostPublicationEvent {
  id           String               @id @default(cuid())
  postId       String
  type         PublicationEventType
  revisionId   String?              // the revision that went (or would go) live; null for UNPUBLISHED/SCHEDULE_CANCELED
  scheduledFor DateTime?            // only set for SCHEDULED events
  actorId      String?              // null = system (the due-schedule sweep)
  createdAt    DateTime             @default(now())

  post     Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  revision Revision? @relation(fields: [revisionId], references: [id])
  actor    User?     @relation("PublicationEventActor", fields: [actorId], references: [id])

  @@index([postId, createdAt])
}

model PostCollab {
  postId    String   @id
  ydoc      Bytes
  updatedAt DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

// Append-only log of raw Yjs updates for a post's current (unpublished) collab
// session, used to replay/scrub through in-progress editing history. Reset
// (deleted) every time a revision is created — see PLAN.md §3a: this is
// working-session state, not part of the immutable revision history.
model PostCollabUpdate {
  id        BigInt   @id @default(autoincrement())
  postId    String
  createdAt DateTime @default(now())
  update    Bytes

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, id])
}

model SiteSettings {
  id                      Int               @id @default(1)
  defaultModerationPolicy ModerationPolicy  @default(ALWAYS)
  trustThreshold          Int               @default(3)
}

model Commenter {
  id            String  @id @default(cuid())
  userId        String? @unique
  email         String  @unique
  displayName   String
  approvedCount Int     @default(0)
  forceModerate Boolean @default(false)

  user     User?     @relation(fields: [userId], references: [id])
  comments Comment[]
}

model CommentThread {
  id                 String       @id @default(cuid())
  postId             String
  anchoredRevisionId String
  anchorFrom         Int
  anchorTo           Int
  quotedText         String
  status             ThreadStatus @default(ACTIVE)
  createdAt          DateTime     @default(now())

  post     Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  revision Revision  @relation(fields: [anchoredRevisionId], references: [id])
  comments Comment[]
}

model Comment {
  id                String        @id @default(cuid())
  threadId          String
  parentCommentId   String?
  commenterId       String
  body              Json
  status            CommentStatus @default(PENDING)
  ipAddress         String?
  statusChangedById String?
  statusChangedAt   DateTime?
  createdAt         DateTime      @default(now())
  editedAt          DateTime?
  deletedByUserId   String?
  deletedAt         DateTime?

  thread          CommentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  parent          Comment?      @relation("CommentReplies", fields: [parentCommentId], references: [id])
  replies         Comment[]     @relation("CommentReplies")
  commenter       Commenter     @relation(fields: [commenterId], references: [id])
  statusChangedBy User?         @relation("CommentStatusChangedBy", fields: [statusChangedById], references: [id])
  deletedBy       User?         @relation("CommentDeletedBy", fields: [deletedByUserId], references: [id])
}
