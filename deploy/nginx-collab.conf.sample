# MultiBlog — nginx server block for the Hocuspocus collab websocket. See DEPLOY.md §7.
# Copy to /etc/nginx/sites-available/, symlink into sites-enabled/, then:
#   sudo nginx -t && sudo systemctl reload nginx
# Replace <collab-host> and the TLS lines with your hostname / your SSL method.
#
# Alternative (avoids a second cert): drop this file and instead add a
# `location /collab/ { ... }` block to the app server above with the same
# upgrade headers, then set NEXT_PUBLIC_COLLAB_URL=wss://<app-host>/collab.

server {
    listen 80;
    listen [::]:80;
    server_name <collab-host>;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name <collab-host>;

    # --- TLS: replace with your certs / your SSL method ---
    ssl_certificate     /etc/ssl/<collab-host>/fullchain.pem;
    ssl_certificate_key /etc/ssl/<collab-host>/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:1234;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 3600s;      # keep idle editing sockets alive
        proxy_send_timeout 3600s;
    }
}
