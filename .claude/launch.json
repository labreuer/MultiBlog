{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "web-prod",
      "runtimeExecutable": "pwsh",
      "runtimeArgs": [
        "-NoProfile",
        "-Command",
        "$env:AUTH_TRUST_HOST='true'; $env:AUTH_URL='http://localhost:3001'; npx next start -p 3001"
      ],
      "port": 3001
    },
    {
      "name": "collab",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "collab"],
      "port": 1234
    }
  ]
}
